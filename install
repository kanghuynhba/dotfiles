#!/usr/bin/env bash

set -e

CONFIG=".install.conf.yaml"
DOTBOT_DIR=".dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"

# Change default shell to zsh if it isn't already
# Using full paths to prevent PATH hijacking
if [ "$SHELL" != "/bin/zsh" ] && [ "$SHELL" != "/usr/bin/zsh" ]; then
    if [ -x "/bin/zsh" ]; then
        chsh -s "/bin/zsh" || echo "Warning: Unable to change login shell automatically."
    elif [ -x "/usr/bin/zsh" ]; then
        chsh -s "/usr/bin/zsh" || echo "Warning: Unable to change login shell automatically."
    else
        echo "Skipping login shell change because zsh is not found."
    fi
fi
