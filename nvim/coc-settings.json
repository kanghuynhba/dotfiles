{
  // ── Completion ────────────────────────────────────────────────────────────
  "suggest.noselect": false,
  "suggest.enablePreselect": false, // noselect=false already pre-selects; don't set both
  "suggest.completionItemKindLabels": true,
  "suggest.triggerAfterInsertEnter": true,
  "suggest.acceptSuggestionOnCommitCharacter": false,
  "suggest.maxCompleteItemCount": 20,

  // ── Diagnostics ───────────────────────────────────────────────────────────
  "diagnostic.displayByAle": false, // ALE only lints sh/vim; coc owns diagnostics
  "diagnostic.errorSign": "✖",
  "diagnostic.warningSign": "⚠",
  "diagnostic.infoSign": "ℹ",
  "diagnostic.hintSign": "➤",
  "diagnostic.checkCurrentLine": true,
  "diagnostic.virtualText": true,
  "diagnostic.virtualTextCurrentLineOnly": false,
  "diagnostic.refreshAfterSave": false,
  "diagnostic.messageTarget": "float",

  // ── Inlay Hints ───────────────────────────────────────────────────────────
  "inlayHint.enable": true,
  "inlayHint.display": true,

  // ── Format on save (controlled in coc.vim autocmds; listed here too) ──────
  "coc.preferences.formatOnSaveFiletypes": [
    "rust",
    "python",
    "go",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "json",
    "yaml",
    "lua"
  ],

  // ── Snippets ──────────────────────────────────────────────────────────────
  "snippets.ultisnips.directories": ["~/.config/nvim/UltiSnips"],
  "snippets.autoTrigger": true,

  // ── Rust (coc-rust-analyzer) ──────────────────────────────────────────────
  "rust-analyzer.checkOnSave.command": "clippy",
  "rust-analyzer.checkOnSave.allTargets": true,
  "rust-analyzer.inlayHints.chainingHints.enable": true,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.typeHints.enable": true,
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.lens.enable": true,
  "rust-analyzer.lens.run.enable": true,
  "rust-analyzer.lens.debug.enable": true,
  "rust-analyzer.procMacro.enable": true,

  // ── Python (coc-pyright) ──────────────────────────────────────────────────
  "python.linting.enabled": true,
  "pyright.inlayHints.functionReturnTypes": true,
  "pyright.inlayHints.variableTypes": true,
  "pyright.inlayHints.parameterTypes": true,
  // Pyright uses your virtualenv automatically; set python.pythonPath if needed:
  // "python.pythonPath": "~/.venv/bin/python"

  // ── C/C++ (coc-clangd) ───────────────────────────────────────────────────
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--completion-style=detailed",
    "--header-insertion=iwyu",
    "--suggest-missing-includes",
    "--inlay-hints=true"
  ],
  // Point to your compile_commands.json directory if needed:
  // "clangd.compilationDatabasePath": "${workspaceFolder}/build"

  // ── Java (coc-java) ───────────────────────────────────────────────────────
  "java.format.enabled": true,
  "java.import.gradle.enabled": true,
  "java.import.maven.enabled": true,
  "java.completion.importOrder": ["java", "javax", "com", "org"],
  "java.inlayHints.parameterNames.enabled": "all",

  // ── Go (coc-go) ───────────────────────────────────────────────────────────
  "go.goplsOptions": {
    "analyses": {
      "unusedparams": true,
      "shadow": true
    },
    "staticcheck": true,
    "usePlaceholders": true
  },

  // ── TypeScript/JavaScript (coc-tsserver) ──────────────────────────────────
  "tsserver.enable": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.variableTypes.enabled": true,
  "typescript.inlayHints.returnTypes.enabled": true,
  "javascript.inlayHints.parameterNames.enabled": "all",

  // ── Lua (coc-lua / lua-language-server) ───────────────────────────────────
  "Lua.diagnostics.globals": ["vim"], // Neovim config globals
  "Lua.workspace.library": {
    "${3rd}/luv/library": true
  },

  // ── Shell (coc-sh → bash-language-server) ────────────────────────────────
  // ALE already handles shellcheck linting; bash-language-server adds
  // completion and hover, which ALE doesn't provide.
  "bashIde.globPattern": "**/*@(.sh|.inc|.bash|.command)",

  // ── JSON / YAML / TOML ────────────────────────────────────────────────────
  "json.schemas": [], // Add project-specific schemas here
  "yaml.schemas": {}, // e.g. {"kubernetes": "*.yaml"}
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,

  // ── Pairs (coc-pairs) ─────────────────────────────────────────────────────
  "pairs.enableCharacters": ["(", "[", "{", "'", "\"", "`"],
  "pairs.alwaysPairCharacters": [],

  // ── Highlight (coc-highlight) ─────────────────────────────────────────────
  "highlight.document.enable": true,
  "highlight.colors.enable": true // Show hex color preview inline
}
